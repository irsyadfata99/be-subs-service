# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=payment_reminder_dev
DB_PORT=3306

# JWT
JWT_SECRET=your_super_secret_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Tripay
TRIPAY_API_KEY=your_api_key_from_dashboard
TRIPAY_PRIVATE_KEY=your_private_key_from_dashboard
TRIPAY_MERCHANT_CODE=T1234
TRIPAY_MODE=sandbox
TRIPAY_API_URL=https://tripay.co.id/api-sandbox

# WhatsApp (Fonnte)
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_TOKEN=your_fonnte_token_from_dashboard

SKIP_EXTERNAL_API=true
# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000